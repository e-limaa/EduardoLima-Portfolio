{
  "name": "limia-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:portfolio": "npm run dev --workspace @limia/portfolio",
    "dev:docs": "npm run dev --workspace @limia/design-system-docs",
    "build:tokens": "npm run build --workspace @limia/tokens",
    "build:design-system": "npm run build --workspace @limia/design-system",
    "check-parity": "node scripts/check-i18n-parity.js",
    "test:a11y": "npm run test:a11y --workspace @limia/tokens",
    "check": "npm run check-parity && npm run test:a11y",
    "build": "npm run build:tokens && npm run build:design-system && npm run check-parity && npm run build --workspace @limia/design-system-docs && npm run build --workspace @limia/portfolio",
    "install:workspaces": "npm install"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.8.2"
  }
}
