{
  "name": "@limia/design-system",
  "version": "0.1.0",
  "description": "Limia Design System runtime package.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "COMPONENT_STATUS.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-assets.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@limia/tokens": "file:../limia-tokens",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^12.23.24",
    "react-hook-form": "^7.55.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind/preset.d.ts",
      "default": "./dist/tailwind/preset.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles/globals.css": "./dist/styles.css"
  }
}
